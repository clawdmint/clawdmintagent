// Clawdmint Database Schema
// Platform for AI agent NFT deployments

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════
// AGENT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

// AgentStatus values: PENDING, CLAIMED, VERIFIED, SUSPENDED, BANNED

model Agent {
  id            String        @id @default(cuid())
  name          String
  eoa           String        @unique // Ethereum address (checksummed)
  description   String?
  avatarUrl     String?
  xHandle       String?       // Twitter/X handle (optional)
  ownerWalletAddress String?
  ownerWalletChain String?    @default("solana")
  studioEnabled  Boolean      @default(false)
  openclawAgentId String?     @unique
  openclawWorkspacePath String?
  openclawWorkspaceVersion Int @default(1)
  openclawStatus String?      @default("inactive")
  openclawChatEnabled Boolean @default(false)
  persona       String?
  soulProfile   Json?
  solanaWalletAddress String? @unique
  solanaWalletEncryptedKey String?
  solanaWalletExportedAt DateTime?
  metaplexCollectionAddress String?
  metaplexCollectionUri String?
  metaplexAssetAddress String? @unique
  metaplexAssetUri String?
  metaplexRegistrationUri String?
  metaplexIdentityPda String?
  metaplexExecutiveProfilePda String?
  metaplexExecutionDelegatePda String?
  metaplexRegisteredAt DateTime?
  metaplexDelegatedAt DateTime?
  synapseSapAgentPda String? @unique
  synapseSapStatsPda String?
  synapseSapTxSignature String?
  synapseSapRegisteredAt DateTime?

  // Authentication
  hmacKeyHash   String?       // Hashed HMAC key for API authentication
  
  // Notifications
  telegramChatId String?      // Telegram chat ID for mint notifications
  
  // Verification status (PENDING, CLAIMED, VERIFIED, SUSPENDED, BANNED)
  status        String        @default("PENDING")
  deployEnabled Boolean       @default(false)
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  verifiedAt    DateTime?
  
  // Relations
  claims        AgentClaim[]
  collections   Collection[]
  tokenLaunches TokenLaunch[]
  clawPegLaunches ClawPegLaunch[]
  studioSkills  AgentSkillInstall[]
  studioSessions AgentStudioSession[]
  studioRuns    AgentStudioRun[]
  followers     AgentFollow[]
  @@index([eoa])
  @@index([status])
  @@index([metaplexAssetAddress])
  @@index([metaplexIdentityPda])
  @@index([synapseSapAgentPda])
  @@index([ownerWalletAddress])
}

model AgentFollow {
  id            String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletAddress  String
  walletChain    String   @default("solana")
  createdAt      DateTime @default(now())

  @@unique([agentId, walletAddress])
  @@index([walletAddress])
  @@index([agentId, createdAt])
}

model FairscaleScoreCache {
  walletAddress String   @id
  payload       Json
  availability  String   @default("available")
  fetchedAt     DateTime
  expiresAt     DateTime
  updatedAt     DateTime @updatedAt

  @@index([expiresAt])
  @@index([availability, updatedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// VERIFICATION CLAIMS
// ═══════════════════════════════════════════════════════════════════════

// ClaimStatus values: PENDING, VERIFIED, EXPIRED, FAILED

model AgentClaim {
  id          String      @id @default(cuid())
  agentId     String
  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Claim details
  claimCode   String      @unique // e.g., CLAWDMINT-AGENT-9K2F
  
  // Verification data
  signature   String?     // EIP-191 signature of claim code
  tweetUrl    String?     // Optional Twitter verification
  tweetId     String?     // Tweet ID for API lookup
  
  // Status (PENDING, VERIFIED, EXPIRED, FAILED)
  status      String      @default("PENDING")
  expiresAt   DateTime
  verifiedAt  DateTime?
  
  // Timestamps
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([claimCode])
  @@index([agentId])
}

// ═══════════════════════════════════════════════════════════════════════
// NFT COLLECTIONS
// ═══════════════════════════════════════════════════════════════════════

// CollectionStatus values: DEPLOYING, ACTIVE, PAUSED, SOLD_OUT, FAILED

model Collection {
  id              String    @id @default(cuid())
  
  // On-chain data
  address         String    @unique // Contract or program-derived collection address
  deployTxHash    String    // Deployment transaction hash or Solana signature
  chain           String    @default("base") // base, base-sepolia, solana, solana-devnet
  authorityAddress String?
  
  // Agent relation
  agentId         String
  agent           Agent     @relation(fields: [agentId], references: [id])
  agentEoa        String    // Denormalized for quick access
  
  // Collection metadata
  name            String
  symbol          String
  description     String?
  imageUrl        String?   // Collection cover image
  baseUri         String    // IPFS base URI
  mintEngine      String    @default("legacy_solana_program") // legacy_solana_program, metaplex_core_candy_machine
  mintAddress     String?   // Candy Machine address for Metaplex-powered mints
  
  // Mint parameters
  maxSupply       Int
  mintPrice       String    // Wei amount as string (bigint)
  royaltyBps      Int       // Royalty in basis points
  payoutAddress   String
  
  // Mint tracking
  totalMinted     Int       @default(0)
  
  // Status (DEPLOYING, ACTIVE, PAUSED, SOLD_OUT, FAILED)
  status          String    @default("DEPLOYING")
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deployedAt      DateTime?
  
  // Relations
  mints           Mint[]
  mintIntents     MintIntent[]
  assets          Asset[]
  listings        Listing[]
  sales           Sale[]
  
  @@index([agentId])
  @@index([address])
  @@index([chain])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════
// MINT TRACKING
// ═══════════════════════════════════════════════════════════════════════

model Mint {
  id            String     @id @default(cuid())
  
  // Collection relation
  collectionId  String
  collection    Collection @relation(fields: [collectionId], references: [id])
  
  // Mint details
  minterAddress String
  quantity      Int
  totalPaid     String     // Wei amount as string
  txHash        String     @unique
  
  // Token IDs
  startTokenId  Int
  endTokenId    Int
  assetAddresses String?   // JSON array of minted Metaplex asset addresses
  
  // Timestamps
  createdAt     DateTime   @default(now())
  mintedAt      DateTime   // Block timestamp

  // Relations
  assets        Asset[]
  
  @@index([collectionId])
  @@index([minterAddress])
  @@index([txHash])
}

model Asset {
  id            String     @id @default(cuid())

  // Relations
  collectionId  String
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mintId        String?
  mint          Mint?      @relation(fields: [mintId], references: [id], onDelete: SetNull)

  // On-chain identity
  assetAddress  String     @unique
  tokenId       Int
  ownerAddress  String

  // Metadata
  name          String
  imageUrl      String?
  metadataUri   String?

  // Timestamps
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  mintedAt      DateTime

  // Relations
  listings      Listing[]
  sales         Sale[]

  @@unique([collectionId, tokenId])
  @@index([collectionId, ownerAddress])
  @@index([ownerAddress])
}

// ListingStatus values: ACTIVE, CANCELLED, FILLED, EXPIRED
model Listing {
  id             String     @id @default(cuid())

  // Relations
  assetId        String
  asset          Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  // Listing details
  sellerAddress  String
  priceLamports  String
  status         String     @default("ACTIVE")
  signature      String
  message        String
  nonce          String     @unique
  expiresAt      DateTime

  // Timestamps
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  cancelledAt    DateTime?
  filledAt       DateTime?

  // Relations
  sales          Sale[]

  @@index([collectionId, status, createdAt])
  @@index([assetId, status])
  @@index([sellerAddress, status])
}

model Sale {
  id                   String     @id @default(cuid())

  // Relations
  assetId              String
  asset                Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  collectionId         String
  collection           Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  listingId            String?
  listing              Listing?   @relation(fields: [listingId], references: [id], onDelete: SetNull)

  // Sale details
  buyerAddress         String
  sellerAddress        String
  priceLamports        String
  marketplaceFeeLamports String?
  royaltyLamports      String?
  txHash               String?    @unique

  // Timestamps
  createdAt            DateTime   @default(now())
  soldAt               DateTime

  @@index([collectionId, soldAt])
  @@index([assetId, soldAt])
  @@index([buyerAddress])
  @@index([sellerAddress])
}

model MintIntent {
  id             String     @id @default(cuid())

  // Collection relation
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  // Intent details
  walletAddress  String
  quantity       Int
  totalPaid      String
  assetAddresses String     // JSON array of expected Metaplex asset addresses

  // Lifecycle
  expiresAt      DateTime
  consumedAt     DateTime?
  txHash         String?

  // Timestamps
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([collectionId])
  @@index([walletAddress])
  @@index([expiresAt])
  @@index([txHash])
}

// ═══════════════════════════════════════════════════════════════════════
// AGENT CHAT (Live Chat on Collection Pages)
// ═══════════════════════════════════════════════════════════════════════

model ChatMessage {
  id              String    @id @default(cuid())
  
  // Which collection page this message belongs to
  collectionId    String
  
  // Sender info
  senderType      String    // "agent" or "user"
  senderAddress   String?   // Wallet address for users, EOA for agents
  senderName      String    // Agent name or truncated wallet
  
  // Message content
  content         String
  
  // Timestamps
  createdAt       DateTime  @default(now())
  
  @@index([collectionId, createdAt])
  @@index([senderAddress])
}

// ═══════════════════════════════════════════════════════════════════════
// REPLAY PROTECTION
// ═══════════════════════════════════════════════════════════════════════

model UsedNonce {
  id        String   @id @default(cuid())
  agentId   String
  nonce     String
  usedAt    DateTime @default(now())
  
  @@unique([agentId, nonce])
  @@index([agentId])
}

// ═══════════════════════════════════════════════════════════════════════
// WHITELIST ENTRIES
// ═══════════════════════════════════════════════════════════════════════

model WhitelistEntry {
  id              String   @id @default(cuid())
  walletAddress   String   @unique
  twitterHandle   String?
  completedTasks  String   // JSON array of completed task IDs
  createdAt       DateTime @default(now())
  
  @@index([walletAddress])
}

// ═══════════════════════════════════════════════════════════════════════
// TOKEN LAUNCHES
// ═══════════════════════════════════════════════════════════════════════

model TokenLaunch {
  id              String    @id @default(cuid())
  agentId         String?
  agent           Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  
  tokenName       String
  tokenSymbol     String
  tokenAddress    String    @unique
  poolId          String?
  txHash          String?
  launchType      String?
  network         String?
  genesisAccount  String?
  launchId        String?
  launchUrl       String?
  
  description     String?
  imageUrl        String?
  websiteUrl      String?
  tweetUrl        String?
  chain           String    @default("base")
  
  launcherAddress String
  feeRecipient    String
  setOnAgent      Boolean   @default(false)
  feeDistribution String?   // JSON — fee breakdown from Bankr
  
  simulated       Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  
  @@index([agentId])
  @@index([launcherAddress])
  @@index([tokenAddress])
  @@index([createdAt])
}

// ClawPEG launch records. cPEG is a Solana Token-2022 + PEG registry standard,
// separate from Metaplex collection launches and separate from P2P marketplace listings.
model ClawPegLaunch {
  id                   String   @id @default(cuid())
  agentId              String?
  agent                Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  tokenLaunchId         String?
  marketListings        ClawPegMarketListing[]

  name                 String
  symbol               String
  tokenMint            String   @unique
  collectionAddress    String?  @unique
  hookValidationAddress String? @unique
  hookProgramId        String?
  chain                String   @default("solana")
  cluster              String   @default("mainnet-beta")

  rendererId           String
  rendererVersion      String
  rendererHash         String
  collectionSeed       String
  rendererParams       Json?

  pegUnitRaw           String
  maxPegs              Int
  royaltyBps           Int      @default(0)
  marketplaceFeeBps    Int      @default(0)
  launchFeeLamports    String   @default("0")
  premiumIndexing      Boolean  @default(false)
  partnerApiEnabled    Boolean  @default(false)
  whiteLabelDomain     String?
  identityMode         String   @default("standalone")
  standardMode         String   @default("metaplex_hybrid")
  canonicalRoot        String?
  agentAssetAddress    String?
  agentIdentityPda     String?
  agentCollectionAddress String?
  agentWalletAddress   String?
  agentRegistryProgramId String?
  identityLink         Json?
  agentTokenMint       String?
  hybridProgramId      String?
  hybridEscrowAddress  String?
  hybridCoreCollectionAddress String?
  hybridAssetCollectionAddress String?
  hybridSwapAmountRaw  String?
  hybridCaptureFeeLamports String?
  hybridReroll         Boolean  @default(true)
  hybridStatus         String   @default("NOT_CONFIGURED")
  hybridPlan           Json?
  hybridSetupTxHash    String?
  hybridConfiguredAt   DateTime?
  hybridAssets         ClawPegHybridAsset[]

  authorityAddress     String
  creatorAddress       String
  feeVaultAddress      String
  deployTxHash         String?
  status               String   @default("DRAFT")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  launchedAt           DateTime?

  @@index([agentId])
  @@index([tokenMint])
  @@index([collectionAddress])
  @@index([status])
  @@index([identityMode])
  @@index([standardMode])
  @@index([agentAssetAddress])
  @@index([agentIdentityPda])
  @@index([agentTokenMint])
  @@index([hybridStatus])
  @@index([createdAt])
}

// cPEG P2P escrow marketplace listings. Separate from legacy Metaplex marketplace
// models and separate from cPEG launch/registry state.
model ClawPegMarketListing {
  id                   String   @id @default(cuid())
  launchId             String
  launch               ClawPegLaunch @relation(fields: [launchId], references: [id], onDelete: Cascade)

  tokenMint            String
  collectionAddress    String
  listingAddress       String   @unique
  escrowOwnerPegAddress String
  escrowTokenAccount   String
  pegRecordAddress     String
  pegId                Int

  sellerAddress        String
  priceLamports        String
  marketplaceFeeBps    Int      @default(0)
  royaltyBps           Int      @default(0)
  status               String   @default("ACTIVE")

  listTxHash           String?  @unique
  buyTxHash            String?  @unique
  cancelTxHash         String?  @unique
  buyerAddress         String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  listedAt             DateTime?
  soldAt               DateTime?
  cancelledAt          DateTime?

  @@unique([tokenMint, pegId])
  @@index([launchId, status, createdAt])
  @@index([sellerAddress, status])
  @@index([buyerAddress])
}

// cPEG Metaplex Hybrid asset inventory. Tracks deterministic Metaplex Core PEG
// assets minted by the agent wallet for a hybrid cPEG launch. One row per Core
// asset; the row moves between OWNER (held by capturer) and POOL (held back in
// agent vault, available to capture again) as users capture and release.
model ClawPegHybridAsset {
  id                   String   @id @default(cuid())
  launchId             String
  launch               ClawPegLaunch @relation(fields: [launchId], references: [id], onDelete: Cascade)

  tokenMint            String
  collectionAddress    String
  assetAddress         String   @unique
  pegId                Int
  ownerAddress         String
  status               String   @default("OWNED")

  captureTxHash        String?
  releaseTxHash        String?
  capturedAt           DateTime?
  releasedAt           DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([launchId, pegId])
  @@index([launchId, status])
  @@index([ownerAddress])
  @@index([tokenMint])
}

model AgentSkillInstall {
  id          String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillKey     String
  title        String
  description  String?
  sourceUrl    String?
  enabled      Boolean  @default(true)
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([agentId, skillKey])
  @@index([agentId, enabled])
}

model AgentStudioSession {
  id                String   @id @default(cuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ownerWalletAddress String
  title             String?
  openclawSessionId String?  @unique
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastMessageAt     DateTime @default(now())

  messages          AgentStudioMessage[]
  runs              AgentStudioRun[]

  @@index([agentId, createdAt])
  @@index([ownerWalletAddress, updatedAt])
}

model AgentStudioMessage {
  id          String   @id @default(cuid())
  sessionId    String
  session      AgentStudioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String
  eventType   String?  @default("text")
  toolName    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
}

model AgentStudioRun {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sessionId       String?
  session         AgentStudioSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actionType      String
  title           String
  status          String   @default("queued")
  input           Json?
  output          Json?
  txHash          String?
  externalRunId   String?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([agentId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status])
}
