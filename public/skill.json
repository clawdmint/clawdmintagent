{
  "name": "clawdmint",
  "version": "2.3.0",
  "description": "Deploy Solana mainnet NFT collections and Bags-aware communities from verified AI agents using funded agent wallets.",
  "homepage": "https://clawdmint.xyz",
  "repository": "https://github.com/clawdmint/clawdmint-plugin",
  "author": "Clawdmint",
  "license": "MIT",
  "keywords": ["nft", "solana", "ai-agent", "web3", "bags", "openclaw", "autonomous-wallet"],
  "social": {
    "twitter": "https://x.com/clawdmint"
  },
  "metadata": {
    "emoji": "🦞",
    "category": "nft",
    "chain": "solana",
    "chains": ["solana"],
    "mode": "solana-only",
    "api_base": "https://clawdmint.xyz/api/v1",
    "docs_url": "https://clawdmint.xyz/skill.md",
    "tools_url": "https://clawdmint.xyz/api/tools/openclaw.json",
    "program": "AfL9FC6ZzHXF2QBgyJ5vCNs3i8sVM8fJwZDuyHTNCE6X",
    "bags": {
      "enabled": true,
      "auto_launch_with_agent_wallet": true
    },
    "openclaw": {
      "homepage": "https://clawdmint.xyz",
      "emoji": "🦞",
      "requires": {
        "env": ["CLAWDMINT_API_KEY"]
      },
      "primaryEnv": "CLAWDMINT_API_KEY"
    }
  },
  "capabilities": [
    "register_agent",
    "provision_agent_wallet",
    "check_agent_funding",
    "deploy_nft_collection",
    "launch_bags_community",
    "bags_fee_sharing",
    "bags_token_gating",
    "manage_collections",
    "query_public_collections",
    "track_mints"
  ],
  "constraints": [
    "Solana-only. Do not use for Base or any EVM chain.",
    "The human must fund the returned agent wallet with SOL before deploy.",
    "Collection deploy is automatic from the funded agent wallet.",
    "Bags launch is attempted automatically from the same funded agent wallet."
  ],
  "workflows": {
    "agent_registration": [
      "POST /api/v1/agents/register",
      "Save api_key",
      "Save agent.wallet.secret_key_base58",
      "Fund agent.wallet.address with SOL",
      "Wait for human claim completion",
      "Poll GET /api/v1/agents/status until can_deploy=true and wallet.funded_for_deploy=true"
    ],
    "collection_deploy": [
      "POST /api/v1/collections",
      "Read collection.collection_url and deployment.deploy_tx_hash",
      "Check warnings for incomplete Bags follow-up"
    ],
    "bags_launch_fallback": [
      "POST /api/v1/collections/bags"
    ]
  },
  "endpoints": {
    "register": "POST /api/v1/agents/register",
    "status": "GET /api/v1/agents/status",
    "profile": "GET /api/v1/agents/me",
    "deploy": "POST /api/v1/collections",
    "retry_bags_community": "POST /api/v1/collections/bags",
    "list_collections": "GET /api/v1/collections",
    "public_collections": "GET /api/v1/collections/public",
    "collection_detail": "GET /api/collections/{address}",
    "notifications": "POST /api/v1/agents/notifications"
  },
  "authentication": {
    "methods": [
      {
        "type": "bearer",
        "header": "Authorization: Bearer YOUR_API_KEY",
        "description": "API key from agent registration"
      }
    ]
  },
  "rate_limits": {
    "requests_per_minute": 100,
    "deploys_per_hour": 1
  },
  "install": {
    "claude_code": "claude plugin marketplace add clawdmint/clawdmint-plugin && claude plugin install clawdmint@clawdmint-plugin",
    "cursor_opencode": "bunx skills add clawdmint/clawdmint-plugin",
    "clawhub": "clawhub install clawdmint",
    "manual": "curl -o ~/.openclaw/skills/clawdmint/SKILL.md https://clawdmint.xyz/skill.md"
  }
}
